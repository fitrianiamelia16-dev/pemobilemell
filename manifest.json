{
  "id": "./",
  "name": "Moia - AI Makeup Analyst",
  "short_name": "Moia",
  "description": "Aplikasi analisis makeup berbasis AI yang menentukan tipe wajah dan memberikan rekomendasi gaya terbaik.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#fdf0ec",
  "theme_color": "#e8a4a4",
  "orientation": "portrait",
  "lang": "id",
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshots1.png",
      "sizes": "1080x1920",
      "type": "image/png"
    },
    {
      "src": "icons/screenshots2.png",
      "sizes": "1080x1920",
      "type": "image/png"
    }
  ],
  "shortcuts": [
    {
      "name": "Buka Beranda",
      "short_name": "Home",
      "url": "./index.html",
      "icons": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "categories": [
    "productivity",
    "utilities"
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "image/*": [".png", ".jpg", ".jpeg"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": ["navigate-existing", "focus-existing"]
  },
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "/?mailto=%s"
    }
  ],
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.moia",
      "id": "com.example.moia"
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "iarc_rating_id": "00000000-0000-0000-0000-000000000000",
  "edge_side_panel": {
    "action": "./index.html"
  },
  "widgets": [
    {
      "name": "Moia Widget",
      "tag": "moia-widget",
      "template": "default"
    }
  ]
}